<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.parisara.cycle.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_map"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_home_to_buddy"
            app:destination="@id/buddyFragment" />
        <action
            android:id="@+id/action_home_to_report"
            app:destination="@id/reportFragment" />
        <action
            android:id="@+id/action_home_to_stats"
            app:destination="@id/statsFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.parisara.cycle.ui.map.MapFragment"
        android:label="Safe Map" />

    <fragment
        android:id="@+id/buddyFragment"
        android:name="com.parisara.cycle.ui.buddy.BuddyFragment"
        android:label="Buddy" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.parisara.cycle.ui.stats.StatsFragment"
        android:label="Stats" />

    <fragment
        android:id="@+id/reportFragment"
        android:name="com.parisara.cycle.ui.report.ReportFragment"
        android:label="Report" />

</navigation>
