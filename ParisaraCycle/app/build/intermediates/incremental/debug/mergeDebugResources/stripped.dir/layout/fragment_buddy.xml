<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F7F0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👥 Buddy System"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/green_primary"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_my_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your ID: —"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_buddy_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 cyclist(s) near you"
        android:textSize="15sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚴 No cyclists nearby yet.\nShare the app and ride together!"
        android:textColor="#888888"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="visible"
        android:layout_marginTop="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_buddies"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
